# Temporal connection settings (used by both the Worker and the Client).
# Defaults target a local dev server, so these are optional for local runs.
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=money-transfer

# Address where the Worker exposes Prometheus SDK metrics (scrape path: /metrics).
PROMETHEUS_BIND_ADDRESS=0.0.0.0:9464
